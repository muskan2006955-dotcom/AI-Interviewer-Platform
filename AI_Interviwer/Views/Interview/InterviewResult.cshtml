@model AI_Interviwer.Models.InterviewSession

@{
    ViewData["Title"] = "Interview Performance Analytics";
    int scorePercentage = ViewBag.ScorePercentage ?? 0;
    // 🔥 Pink-purple theme integration based on score tiers
    string progressColor = scorePercentage >= 70 ? "#d946ef" : (scorePercentage >= 45 ? "#a855f7" : "#ff4a4a");
}

<div class="interview-result-container">
    <div class="glass-panel summary-header">
        <div class="header-info">
            <h2 class="text-white fw-bold">Interview Performance Report</h2>
            <p class="text-dim">Role: <span class="highlight">@Model.Role (@Model.Level Level)</span> | Focus: <span class="highlight">@Model.InterviewType</span></p>
            <div class="session-meta">
                <span><i class="fas fa-calendar-alt"></i> @Model.CreatedAt?.ToString("dd MMM yyyy, hh:mm tt")</span>
                <span><i class="fas fa-tasks"></i> Attempted: @ViewBag.AttemptedCount / @ViewBag.TotalCount Questions</span>
            </div>
        </div>

        <div class="score-badge-wrapper">
            <div class="score-radial" style="--score-percent: @scorePercentage%; --score-color: @progressColor;">
                <div class="score-inner">
                    <span class="score-number">@scorePercentage%</span>
                    <span class="score-label">Overall Score</span>
                </div>
            </div>
        </div>
    </div>

    <div class="questions-timeline">
        <h3 class="section-title"><i class="fas fa-chart-bar text-pink"></i> Question-by-Question Evaluation</h3>

        @{
            int qIndex = 1;
            var orderedQuestions = Model.SessionQuestions.OrderBy(q => q.CreatedAt).ToList();
        }

        @foreach (var question in orderedQuestions)
        {
            bool isCorrect = question.IsCorrect ?? false;
            string statusBadgeClass = isCorrect ? "badge-success" : "badge-danger";
            string statusText = isCorrect ? "Passed Criteria" : "Review Needed";

            <div class="glass-panel question-card">
                <div class="card-top-bar">
                    <span class="question-number-tag">Question 0@qIndex</span>
                    <div class="card-badges">
                        <span class="score-pill">Score: <strong>@question.Score / 100</strong></span>
                        <span class="status-badge @statusBadgeClass">@statusText</span>
                    </div>
                </div>

                <h4 class="question-text">@question.QuestionText</h4>

                <div class="split-layout-grid">

                    <div class="layout-column left-text-column">
                        <div class="content-block text-answer-block">
                            <h5><i class="fas fa-file-alt"></i> Conceptual Text Solution</h5>
                            <p class="text-data">
                                @if (!string.IsNullOrWhiteSpace(question.UserTextAnswer))
                                {
                                    @question.UserTextAnswer
                                }
                                else
                                {
                                    <span class="text-muted-italic">No textual description recorded for this question.</span>
                                }
                            </p>
                        </div>

                        <div class="content-block ai-feedback-block">
                            <h5><i class="fas fa-robot"></i> Interviewer Feedback</h5>
                            <blockquote class="feedback-quote">
                                @question.AiFeedback
                            </blockquote>
                        </div>
                    </div>

                    <div class="layout-column right-code-column">
                        <div class="content-block code-block-wrapper">
                            <h5><i class="fas fa-code"></i> Submitted Implementation</h5>
                            <div class="code-editor-style-view">
                                <div class="editor-header-dots">
                                    <span class="dot red"></span>
                                    <span class="dot yellow"></span>
                                    <span class="dot green"></span>
                                    <span class="file-name">solution.cs</span>
                                </div>
                                <pre><code>@if (!string.IsNullOrWhiteSpace(question.UserCodeAnswer))
                                    {
                                            @question.UserCodeAnswer
                                    }
                                                                else
                                    {
                                            // No structural source code execution was registered for this prompt.
                                    }
    </code></pre>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            qIndex++;
        }
    </div>

    <div class="action-footer">
        <a asp-action="Dashboard" asp-controller="Home" class="btn-action-back">
            <i class="fas fa-arrow-left me-2"></i> Back to Live Dashboard
        </a>
    </div>
</div>

<style>
    :root {
        --cyber-bg: #090d16;
        --glass-bg: rgba(13, 14, 18, 0.85);
        --glass-border: rgba(217, 70, 239, 0.15);
        --pink-glow: #d946ef;
        --purple-accent: #a855f7;
        --text-bright: #ffffff;
        --text-dim: #94a3b8;
        --text-muted: #64748b;
        --cyber-danger: #ff4a4a;
    }

    body {
        background: radial-gradient(circle at 50% 0%, #151026, var(--cyber-bg)) !important;
        color: var(--text-bright);
        font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
    }

    .interview-result-container {
        max-width: 1300px;
        margin: 40px auto;
        padding: 0 20px;
    }

    /* 🔮 High-Fidelity Glassmorphism Panel Setup */
    .glass-panel {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        padding: 24px;
        margin-bottom: 30px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), 0 0 20px rgba(217, 70, 239, 0.05), inset 0 1px 2px rgba(255, 255, 255, 0.05);
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .glass-panel:hover {
            border-color: rgba(217, 70, 239, 0.35);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6), 0 0 25px rgba(217, 70, 239, 0.2);
        }

    .summary-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        border-left: 4px solid var(--pink-glow);
        box-shadow: -10px 0 25px -10px var(--pink-glow), 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .header-info h2 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: -0.5px;
    }

    .header-info .highlight {
        color: #f472b6;
        text-shadow: 0 0 10px rgba(244, 114, 182, 0.4);
        font-weight: 600;
    }

    .session-meta {
        display: flex;
        gap: 20px;
        margin-top: 15px;
        font-size: 0.9rem;
        color: var(--text-dim);
    }

        .session-meta i {
            margin-right: 6px;
            color: var(--pink-glow);
        }

    /* Radial Radial Core Progress Framework */
    .score-radial {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: conic-gradient(var(--score-color) var(--score-percent), rgba(255, 255, 255, 0.03) 0);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 20px rgba(217, 70, 239, 0.2);
    }

    .score-inner {
        width: 92px;
        height: 92px;
        border-radius: 50%;
        background: #05060a;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .score-number {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--text-bright);
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
    }

    .score-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        color: var(--text-dim);
        letter-spacing: 0.5px;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--text-bright);
        margin: 40px 0 20px 0;
    }

    .question-card {
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .card-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .question-number-tag {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        background: rgba(217, 70, 239, 0.1);
        color: #f472b6;
        padding: 4px 12px;
        border-radius: 6px;
        border: 1px solid rgba(217, 70, 239, 0.3);
    }

    .card-badges {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .score-pill {
        font-size: 0.85rem;
        background: #05060a;
        padding: 4px 12px;
        border-radius: 20px;
        border: 1px solid rgba(217, 70, 239, 0.2);
    }

    .status-badge {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
        letter-spacing: 0.5px;
    }

    .badge-success {
        background: rgba(217, 70, 239, 0.1);
        color: #f472b6;
        border: 1px solid rgba(217, 70, 239, 0.4);
        box-shadow: 0 0 10px rgba(217, 70, 239, 0.2);
    }

    .badge-danger {
        background: rgba(255, 74, 74, 0.08);
        color: var(--cyber-danger);
        border: 1px solid rgba(255, 74, 74, 0.3);
    }

    .question-text {
        font-size: 1.15rem;
        font-weight: 600;
        line-height: 1.5;
        margin-bottom: 24px;
        color: #ffffff;
    }

    .split-layout-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .layout-column {
        display: flex;
        flex-direction: column;
        gap: 16px;
        min-width: 0;
    }

    .content-block h5 {
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
        color: var(--text-dim);
        font-weight: 700;
    }

        .content-block h5 i {
            color: var(--pink-glow);
        }

    .text-data {
        background: #05060a;
        border: 1px solid rgba(217, 70, 239, 0.15);
        border-radius: 8px;
        padding: 16px;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #e5e7eb;
        min-height: 100px;
    }

    .text-muted-italic {
        font-style: italic;
        color: var(--text-muted);
    }

    .feedback-quote {
        background: rgba(168, 85, 247, 0.04);
        border-left: 3px solid var(--purple-accent);
        padding: 14px 16px;
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.5;
        color: #c084fc;
        border-radius: 0 8px 8px 0;
        box-shadow: inset 10px 0 20px -10px rgba(168, 85, 247, 0.1);
    }

    /* Right Side Cyber IDE Editor Console Wrapper */
    .code-editor-style-view {
        background: #05060a;
        border: 1px solid rgba(217, 70, 239, 0.2);
        border-radius: 10px;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .editor-header-dots {
        background: #0d0e12;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 6px;
        border-bottom: 1px solid rgba(217, 70, 239, 0.1);
    }

        .editor-header-dots .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

    .dot.red {
        background: #ff4a4a;
    }

    .dot.yellow {
        background: #f59e0b;
    }

    .dot.green {
        background: #d946ef;
    }

    .editor-header-dots .file-name {
        margin-left: 10px;
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .code-editor-style-view pre {
        margin: 0;
        padding: 16px;
        overflow-x: auto;
        flex-grow: 1;
    }

    .code-editor-style-view code {
        font-family: 'Fira Code', Consolas, Monaco, monospace;
        font-size: 0.88rem;
        line-height: 1.5;
        color: #38bdf8;
        white-space: pre-wrap;
    }

    /* Back To Dashboard Navigation Pipeline */
    .btn-action-back {
        background: rgba(217, 70, 239, 0.05);
        color: #ffffff;
        border: 1px solid rgba(217, 70, 239, 0.3);
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.25s ease;
    }

        .btn-action-back:hover {
            background: linear-gradient(135deg, var(--pink-glow), var(--purple-accent));
            box-shadow: 0 0 25px rgba(217, 70, 239, 0.5);
            border-color: var(--pink-glow);
            color: #ffffff;
        }

    .text-pink {
        color: #f472b6 !important;
    }

    @@media (max-width: 992px) {
        .split-layout-grid

    {
        grid-template-columns: 1fr;
        gap: 16px;
    }

    }
</style>