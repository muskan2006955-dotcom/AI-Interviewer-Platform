@model AI_Interviwer.Models.User

@{
    ViewData["Title"] = "Join AI Interviewer";
}

<style>
    :root {
        --cyber-bg: #090d16;
        --glass-bg: rgba(13, 14, 18, 0.85);
        --glass-border: rgba(217, 70, 239, 0.15);
        --pink-glow: #d946ef;
        --purple-accent: #a855f7;
        --cyan-glow: #06b6d4;
        --text-bright: #ffffff;
        --text-dim: #94a3b8;
    }

    .cyber-auth-wrapper {
        min-height: 85vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: radial-gradient(circle at 50% 30%, rgba(217, 70, 239, 0.08), transparent 50%);
    }

    .cyber-glass-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        width: 420px;
        padding: 35px 30px;
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6), 0 0 25px rgba(217, 70, 239, 0.15), inset 0 1px 2px rgba(255, 255, 255, 0.05);
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .cyber-glass-card:hover {
            border-color: rgba(6, 182, 212, 0.35);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6), 0 0 30px rgba(6, 182, 212, 0.25);
        }

    .cyber-card-title {
        font-weight: 800;
        letter-spacing: -0.5px;
        color: var(--text-bright);
    }

    .neon-text-cyan {
        color: var(--cyan-glow);
        text-shadow: 0 0 15px rgba(6, 182, 212, 0.5);
    }

    .neon-text-pink {
        color: var(--pink-glow);
        text-shadow: 0 0 15px rgba(217, 70, 239, 0.5);
        text-decoration: none;
        font-weight: 600;
        transition: text-shadow 0.2s ease;
    }

        .neon-text-pink:hover {
            text-shadow: 0 0 25px var(--pink-glow);
            color: #f472b6;
        }

    .cyber-form-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-dim);
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .cyber-form-input {
        background-color: #05060a !important;
        border: 1px solid rgba(217, 70, 239, 0.2) !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 12px 14px !important;
        font-size: 0.95rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .cyber-form-input::placeholder {
            color: #475569;
        }

        .cyber-form-input:focus {
            border-color: var(--cyan-glow) !important;
            box-shadow: 0 0 15px rgba(6, 182, 212, 0.3) !important;
        }

    .btn-cyber-submit {
        background: linear-gradient(135deg, var(--pink-glow), var(--purple-accent));
        color: #ffffff !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        padding: 13px 20px;
        border-radius: 8px;
        border: none;
        box-shadow: 0 0 15px rgba(217, 70, 239, 0.3);
        transition: all 0.25s ease;
    }

        .btn-cyber-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 25px rgba(217, 70, 239, 0.5);
        }
</style>

<div class="cyber-auth-wrapper">
    <div class="cyber-glass-card">
        <h3 class="text-center cyber-card-title mb-1">Create <span class="neon-text-cyan">Account</span> 🚀</h3>
        <p class="text-center text-muted small mb-4" style="letter-spacing: 0.5px;">Start your AI mock interview journey</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger bg-dark text-danger border-danger p-2 small text-center" style="border-radius: 8px; background-color: rgba(255, 74, 74, 0.1) !important;">
                <i class="fas fa-exclamation-triangle me-1"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Signup" method="post">
            <div class="mb-3">
                <label class="cyber-form-label"><i class="fas fa-user me-1"></i> Full Name</label>
                <input type="text" name="Name" class="form-control cyber-form-input" required placeholder="e.g., Muskan Mushtaq" />
            </div>
            <div class="mb-3">
                <label class="cyber-form-label"><i class="fas fa-envelope me-1"></i> Email Address</label>
                <input type="email" name="Email" class="form-control cyber-form-input" required placeholder="name@example.com" />
            </div>
            <div class="mb-3">
                <label class="cyber-form-label"><i class="fas fa-lock me-1"></i> Password</label>
                <input type="password" name="PasswordHash" class="form-control cyber-form-input" required placeholder="••••••••" />
            </div>
            <div class="mb-4">
                <label class="cyber-form-label"><i class="fas fa-shield-alt me-1"></i> Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control cyber-form-input" required placeholder="••••••••" />
            </div>
            <button type="submit" class="btn btn-cyber-submit w-100">Sign Up</button>
        </form>

        <p class="text-center mt-4 small text-muted mb-0">
            Already have an account? <a asp-action="Signin" class="neon-text-pink">Login here</a>
        </p>
    </div>
</div>